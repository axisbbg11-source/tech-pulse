---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getArticlesByCategory, categories } from '../data/articles';

const category = categories.find(c => c.id === 'programming');
const articles = getArticlesByCategory('programming');
---

<Layout title="Programming & Development News">
  <section class="category-hero">
    <div class="category-hero-bg"></div>
    <div class="container">
      <span class="category-icon">{category?.icon}</span>
      <h1 class="category-title">{category?.name}</h1>
      <p class="category-desc">Developer tools, programming languages, and coding tutorials</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="articles-grid">
        {articles.map((article, index) => (
          <div class="article-wrapper" style={`--delay: ${index * 0.1}s`}>
            <ArticleCard article={article} />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .category-hero {
    position: relative;
    padding: calc(var(--header-height) + var(--spacing-4xl)) 0 var(--spacing-2xl);
    text-align: center;
    overflow: hidden;
  }

  .category-hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 61, 113, 0.15) 0%, transparent 50%);
    z-index: -1;
  }

  .category-icon {
    font-size: 64px;
    display: block;
    margin-bottom: var(--spacing-lg);
    animation: pulse 2s ease-in-out infinite;
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: clamp(36px, 6vw, 56px);
    font-weight: 800;
    margin-bottom: var(--spacing-md);
  }

  .category-desc {
    font-size: 18px;
    color: var(--text-secondary);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .article-wrapper {
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: var(--delay);
    opacity: 0;
  }

  @media (max-width: 1024px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>