---
import Layout from '../layouts/Layout.astro';
import FeaturedArticle from '../components/FeaturedArticle.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { articles, getFeaturedArticle, categories } from '../data/articles';

const featured = getFeaturedArticle();
const recentArticles = articles.filter(a => a.id !== featured.id).slice(0, 9);
const trending = articles.slice(0, 4);
---

<Layout title="Latest Tech News">
  <!-- Hero / Featured Section -->
  <FeaturedArticle article={featured} />

  <!-- Categories Section -->
  <section class="section categories-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Explore Topics</h2>
        <p class="section-subtitle">Stay updated with the latest in technology</p>
      </div>
      <div class="categories-grid">
        {categories.map((cat, index) => (
          <a href={`/${cat.id}`} class="category-card" style={`--delay: ${index * 0.1}s`}>
            <div class="category-icon">{cat.icon}</div>
            <span class="category-name">{cat.name}</span>
            <div class="category-glow" style={`background: ${cat.color}`}></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Articles Section -->
  <section class="section articles-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Latest News</h2>
        <p class="section-subtitle">Fresh updates from the tech world</p>
      </div>
      <div class="articles-grid">
        {recentArticles.map((article, index) => (
          <div class="article-wrapper" style={`--delay: ${index * 0.1}s`}>
            <ArticleCard article={article} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trending Sidebar Section -->
  <section class="section trending-section">
    <div class="container">
      <div class="trending-layout">
        <div class="trending-main">
          <div class="section-header">
            <h2 class="section-title">
              <span class="title-accent">◈</span> Trending Now
            </h2>
          </div>
          <div class="trending-list">
            {trending.map((article, index) => (
              <a href={`/article/${article.id}`} class="trending-item">
                <span class="trending-number">{String(index + 1).padStart(2, '0')}</span>
                <div class="trending-content">
                  <span class={`badge badge-${article.category}`}>{article.category}</span>
                  <h4 class="trending-title">{article.title}</h4>
                  <div class="trending-meta">
                    <span>{article.author.name}</span>
                    <span>•</span>
                    <span>{article.readTime}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="trending-sidebar">
          <div class="sidebar-card">
            <h3 class="sidebar-title">Newsletter</h3>
            <p class="sidebar-desc">Get the latest tech news delivered to your inbox every morning.</p>
            <form class="sidebar-form" id="sidebarNewsletter">
              <input type="email" placeholder="your@email.com" required />
              <button type="submit">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="22" y1="2" x2="11" y2="13"></line>
                  <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                </svg>
              </button>
            </form>
          </div>

          <div class="sidebar-card social-card">
            <h3 class="sidebar-title">Follow Us</h3>
            <div class="social-grid">
              <a href="#" class="social-btn twitter">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
              <a href="#" class="social-btn github">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
              <a href="#" class="social-btn reddit">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0zm5.01 4.744a.688.688 0 00-.577-.403c-1.69 0-3.059 1.597-3.059 3.568 0 .736.192 1.418.576 1.999l-1.53 1.234c-.096-.192-.192-.384-.288-.576-.336-.576-.792-1.008-1.416-1.152-.624-.144-1.248-.048-1.776.192-.528.24-.816.576-.816 1.008 0 .336.192.624.48.816.864.528 1.824.96 2.808 1.104.984.144 1.728-.048 2.232-.528.504-.48.744-1.104.744-1.752 0-1.152-.528-2.16-1.152-2.808l1.104-1.272c.24-.24.384-.48.384-.768zm-5.01 6.192a.96.96 0 00-.96-.96c-.528 0-.96.432-.96.96 0 .528.432.96.96.96.528 0 .96-.432.96-.96zm-2.496-7.68c-.192 0-.336.048-.432.144-.096.096-.144.216-.144.336 0 .192.072.36.216.504.144.144.336.216.528.216.192 0 .384-.072.528-.216.144-.144.216-.312.216-.504 0-.12-.048-.24-.144-.336-.096-.096-.264-.144-.432-.144z"/>
                </svg>
              </a>
              <a href="#" class="social-btn linkedin">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('sidebarNewsletter');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thanks for subscribing! You\'ll receive the latest tech news in your inbox.');
    (form.querySelector('input') as HTMLInputElement).value = '';
  });
</script>

<style>
  /* Section Styles */
  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
    position: relative;
    display: inline-block;
  }

  .title-accent {
    color: var(--accent-primary);
    margin-right: var(--spacing-sm);
    animation: pulse 2s ease-in-out infinite;
  }

  .section-subtitle {
    font-size: 16px;
    color: var(--text-secondary);
  }

  /* Categories Section */
  .categories-section {
    background: var(--bg-secondary);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--spacing-md);
  }

  .category-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-xl) var(--spacing-md);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-normal);
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: var(--delay);
    opacity: 0;
  }

  .category-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent-primary);
    box-shadow: 0 10px 40px rgba(0, 212, 255, 0.15);
  }

  .category-icon {
    font-size: 32px;
    transition: transform var(--transition-normal);
  }

  .category-card:hover .category-icon {
    transform: scale(1.2);
  }

  .category-name {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .category-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    border-radius: var(--radius-full);
    transition: width var(--transition-normal);
    opacity: 0.5;
  }

  .category-card:hover .category-glow {
    width: 80%;
  }

  /* Articles Section */
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .article-wrapper {
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: var(--delay);
    opacity: 0;
  }

  /* Trending Section */
  .trending-layout {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: var(--spacing-2xl);
  }

  .trending-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .trending-item {
    display: flex;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-normal);
  }

  .trending-item:hover {
    border-color: var(--accent-primary);
    transform: translateX(5px);
  }

  .trending-number {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 800;
    color: var(--accent-primary);
    opacity: 0.5;
    line-height: 1;
  }

  .trending-content {
    flex: 1;
  }

  .trending-title {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
    margin: var(--spacing-sm) 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .trending-meta {
    display: flex;
    gap: var(--spacing-sm);
    font-size: 13px;
    color: var(--text-muted);
  }

  /* Sidebar */
  .trending-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .sidebar-card {
    padding: var(--spacing-xl);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
  }

  .sidebar-title {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
  }

  .sidebar-desc {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
  }

  .sidebar-form {
    display: flex;
    gap: var(--spacing-sm);
  }

  .sidebar-form input {
    flex: 1;
    padding: var(--spacing-md);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: 14px;
  }

  .sidebar-form input::placeholder {
    color: var(--text-muted);
  }

  .sidebar-form input:focus {
    outline: none;
    border-color: var(--accent-primary);
  }

  .sidebar-form button {
    padding: var(--spacing-md);
    background: var(--gradient-primary);
    border: none;
    border-radius: var(--radius-md);
    color: white;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .sidebar-form button:hover {
    transform: scale(1.05);
  }

  /* Social Card */
  .social-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-md);
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    transition: all var(--transition-normal);
  }

  .social-btn:hover {
    color: var(--text-primary);
    border-color: var(--accent-primary);
    transform: translateY(-3px);
  }

  .social-btn.twitter:hover {
    background: rgba(29, 161, 242, 0.1);
    border-color: #1da1f2;
    color: #1da1f2;
  }

  .social-btn.github:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
    color: #fff;
  }

  .social-btn.reddit:hover {
    background: rgba(255, 69, 0, 0.1);
    border-color: #ff4500;
    color: #ff4500;
  }

  .social-btn.linkedin:hover {
    background: rgba(0, 119, 181, 0.1);
    border-color: #0077b5;
    color: #0077b5;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .trending-layout {
      grid-template-columns: 1fr;
    }

    .trending-sidebar {
      flex-direction: row;
    }

    .sidebar-card {
      flex: 1;
    }
  }

  @media (max-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }

    .trending-sidebar {
      flex-direction: column;
    }
  }
</style>